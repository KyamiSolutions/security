# Sisselogimise andmed
ADMIN_USER=admin
ADMIN_PASSWORD=muuda-see-tugeva-parooliga

# IP-kaamera RTSP URL — või jäta tühjaks ja kasuta probe nuppu veebiliidesest
# Märkus: erimärgid paroolil URL-kodeerida (! = %21)
# CAMERA_URL=rtsp://admin:%21Parool@192.168.1.x:554/h264Preview_01_main

# USB-kaamera (kasutatakse ainult kui CAMERA_URL on tühi)
# CAMERA_INDEX=0

HOST=0.0.0.0
PORT=8080

# Teavitused
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# HTTPS (soovitatav välisvõrgu jaoks)
# SSL_CERT=/etc/ssl/certs/kaamera.crt
# SSL_KEY=/etc/ssl/private/kaamera.key
