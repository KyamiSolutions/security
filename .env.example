# Kohustuslik — asenda tugeva parooliga
CAMERA_API_KEY=muuda-see-ara

# Reolink W330 RTSP URL
# Märkus: erimärgid paroolist (nt ! @ #) URL-enkooditakse automaatselt /probe kaudu
# Käsitsi URL-i kasutamisel enkooди parool: ! = %21
# CAMERA_URL=rtsp://admin:%21Maritta66@192.168.1.188:554/h264Preview_01_main

# Teised IP-kaamerad — kasuta /probe veebiliidesest automaatseks avastamiseks
# CAMERA_URL=rtsp://admin:parool@192.168.1.x:554/h264Preview_01_main

# USB-kaamera (kasutatakse ainult kui CAMERA_URL on tühi)
# CAMERA_INDEX=0

HOST=0.0.0.0
PORT=8080

# HTTPS (soovitatav välisvõrgu jaoks)
# SSL_CERT=/etc/ssl/certs/kaamera.crt
# SSL_KEY=/etc/ssl/private/kaamera.key
